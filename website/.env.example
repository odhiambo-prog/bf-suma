# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Analytics 4 (optional — get from https://analytics.google.com)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# External Inventory API (optional — falls back to static catalog)
VITE_INVENTORY_API_KEY=your-inventory-api-key
VITE_INVENTORY_BASE_URL=https://your-inventory.server.com/api

# OpenAI — set this in Vercel dashboard env vars (NOT in .env)
# OPENAI_API_KEY=sk-...
